# ─────────────────────────────────────────────────────────────
# apps/api environment (§4). The app boots and serves all 8 tools with ONLY the required set.
# Optional integrations are feature toggles — missing ones degrade gracefully, never crash.
# ─────────────────────────────────────────────────────────────

# --- required ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yttoolkit
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
IP_HASH_SALT=change-me-to-a-long-random-string   # salt for SHA-256 IP hashing

# --- optional: per-IP rate limit (defaults shown) ---
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=1 minute
LOG_LEVEL=info

# --- optional: Data API enrichment (0..5 keys; the app works with ZERO) ---
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=
YOUTUBE_API_KEY_4=
YOUTUBE_API_KEY_5=

# --- optional: Phase 2 integrations (no-op when absent) ---
# R2 + BullMQ are intentionally NOT implemented (see ARCHITECTURE §10) — listed for parity.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
SENTRY_DSN=                                        # Phase 2: error monitoring (Sentry)
ARCJET_KEY=                                        # Phase 2: edge bot/abuse protection
AXIOM_DATASET=                                     # Phase 2: log shipping (Pino→Axiom)
AXIOM_TOKEN=
# Phase 2 admin: when set (min 16 chars), enables /api/admin/rate-limit-overrides (bearer auth)
ADMIN_API_KEY=

# --- optional: data retention (purge window, days) ---
LOOKUP_RETENTION_DAYS=90
