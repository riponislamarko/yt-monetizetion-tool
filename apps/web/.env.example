# Required: base URL of the Fastify API (apps/api)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional (Phase 2) — leave empty to disable. Every integration is a no-op when unset.

# Sentry error/perf monitoring. Without a DSN the SDK runs with enabled:false (fully inert)
# and the Sentry build wrapper is skipped entirely.
NEXT_PUBLIC_SENTRY_DSN=
# Only used at BUILD time for source-map upload when a DSN is set. Safe to leave empty.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# PostHog product analytics. Without a key, PostHog is never initialised and capture() is a no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
